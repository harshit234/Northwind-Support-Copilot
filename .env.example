# Northwind Support Copilot - Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ============================================================================
# API KEYS (REQUIRED)
# ============================================================================

# Groq API Key (for LLaMA3, Mixtral, Gemma models - FREE tier available)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-actual-groq-key-here

# ============================================================================
# EMBEDDING CONFIGURATION (Local - No API Key Needed!)
# ============================================================================

# Local embedding model via sentence-transformers (runs on your machine)
# Options: all-MiniLM-L6-v2 (fast), all-mpnet-base-v2 (more accurate)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ============================================================================
# LLM CONFIGURATION (Groq Models)
# ============================================================================

# Groq LLM model to use for answer generation
# Options:
#   llama-3.1-8b-instant    - Fast, great for most tasks (RECOMMENDED)
#   llama-3.3-70b-versatile - More capable, best quality
#   llama-3.1-70b-versatile - Capable, good balance
#   gemma2-9b-it            - Google's model, fast
#   mixtral-8x7b-32768      - Large context window (32K tokens)
LLM_MODEL=llama-3.1-8b-instant

# Temperature for answer generation (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.2

# Max tokens in LLM response
LLM_MAX_TOKENS=500

# ============================================================================
# VECTOR DB CONFIGURATION
# ============================================================================

# Chroma database path (leave blank for in-memory, set for persistent)
CHROMA_DB_PATH=./chroma_db

# Chroma collection name
CHROMA_COLLECTION=northwind_support

# ============================================================================
# RETRIEVAL CONFIGURATION
# ============================================================================

# Number of chunks to retrieve per query
RETRIEVAL_TOP_K=3

# Minimum similarity score threshold (0.0-1.0)
RETRIEVAL_SCORE_THRESHOLD=0.7

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable cost tracking (logs API spend per query)
ENABLE_COST_TRACKING=true

# Save query logs to file
LOG_FILE=copilot_queries.log

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable draft reply action (v1 bounded action)
ENABLE_DRAFT_REPLY=true

# Enable conversation history (multi-turn)
ENABLE_CHAT_HISTORY=false

# Enable hallucination detection
ENABLE_HALLUCINATION_CHECK=true

# ============================================================================
# OPTIONAL: ZENDESK INTEGRATION (Phase 2+)
# ============================================================================

# ZENDESK_API_KEY=your-key-here
# ZENDESK_DOMAIN=northwind.zendesk.com
# ZENDESK_EMAIL=support@northwind.com

# ============================================================================
# OPTIONAL: SLACK INTEGRATION (Phase 2+)
# ============================================================================

# SLACK_BOT_TOKEN=xoxb-your-token-here
# SLACK_APP_TOKEN=xapp-your-token-here

# ============================================================================
# DEVELOPMENT / DEBUGGING
# ============================================================================

# Enable debug mode (verbose logging, save intermediate results)
DEBUG=false

# Skip API calls (useful for local testing without spending money)
# MOCK_API=false
